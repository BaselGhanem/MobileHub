rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: get caller's role ──
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAuth()  { return request.auth != null; }
    function isAdmin() { return isAuth() && role() == 'admin'; }
    function isStaff() { return isAuth() && role() in ['admin','tech','cashier']; }

    // ── Users ──
    match /users/{uid} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Devices (Maintenance) ──
    match /devices/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── Sales ──
    match /sales/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Products ──
    match /products/{id} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Stock Purchases ──
    match /stockPurchases/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Other Purchases ──
    match /otherPurchases/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Warehouse ──
    match /warehouse/{id} {
      allow read:  if isStaff();
      allow write: if isStaff();
    }

    // ── Warehouse Movements ──
    match /whMovements/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Employees ──
    match /employees/{id} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Attendance ──
    match /attendance/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── Advances ──
    match /advances/{id} {
      allow read:   if isStaff();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Salary Records ──
    match /salaryRecords/{id} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Insurance Payments ──
    match /insurancePayments/{id} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Settings ──
    match /settings/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Customers ──
    match /customers/{id} {
      allow read:  if isStaff();
      allow write: if isStaff();
    }
  }
}
